{
  "name": "@letmecook/web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^9.15.0",
      "onFail": "error"
    }
  },
  "scripts": {
    "preinstall": "node -e \"if(!process.env.npm_execpath||!process.env.npm_execpath.includes('pnpm')){console.error('This workspace uses pnpm. Run: pnpm install (from repo root)');process.exit(1)}\"",
    "dev": "next dev --port 3001",
    "build": "next build && cp -r public .next/standalone/apps/web/public && cp -r .next/static .next/standalone/apps/web/.next/static",
    "start": "PORT=3001 node --disable-warning=DEP0060 .next/standalone/apps/web/server.js",
    "sync:devicons": "node scripts/sync-devicons.mjs",
    "lint": "eslint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@once-ui-system/core": "^1.6.3",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.74.4",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "devicon": "^2.17.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
