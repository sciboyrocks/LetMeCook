{
  "name": "@letmecook/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^9.15.0",
      "onFail": "error"
    }
  },
  "scripts": {
    "preinstall": "node -e \"if(!process.env.npm_execpath||!process.env.npm_execpath.includes('pnpm')){console.error('This workspace uses pnpm. Run: pnpm install (from repo root)');process.exit(1)}\"",
    "dev": "sh -c 'tsx watch --env-file .env src/worker.ts & tsx watch --env-file .env src/index.ts'",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "worker": "tsx watch --env-file .env src/worker.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/session": "^11.0.1",
    "@fastify/static": "^9.0.0",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.6.2",
    "bullmq": "^5.45.8",
    "fastify": "^5.2.2",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^4.0.2",
    "googleapis": "^171.4.0",
    "ioredis": "^5.10.0",
    "otplib": "^13.3.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/busboy": "^1.5.4",
    "@types/node": "^22.13.11",
    "@types/qrcode": "^1.5.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
