{
  "name": "letmecook-extension",
  "displayName": "LetMeCook",
  "description": "LetMeCook developer OS — dashboard, tasks, and activity tracking inside VS Code.",
  "version": "0.1.0",
  "publisher": "letmecook",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^9.15.0",
      "onFail": "error"
    }
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "LetMeCook",
      "properties": {
        "letmecook.apiUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "LetMeCook API server base URL (overridden by LETMECOOK_URL env var)"
        },
        "letmecook.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for authenticating with the LetMeCook server (overridden by LETMECOOK_API_KEY env var)"
        },
        "letmecook.devDomain": {
          "type": "string",
          "default": "samrudhraikote.me",
          "description": "Domain used for port forwarding URLs, e.g. {port}.samrudhraikote.me (overridden by LETMECOOK_DEV_DOMAIN env var)"
        }
      }
    },
    "commands": [
      {
        "command": "letmecook.openDashboard",
        "title": "LetMeCook: Open Dashboard",
        "icon": "$(home)"
      },
      {
        "command": "letmecook.openTasks",
        "title": "LetMeCook: Open Tasks",
        "icon": "$(tasklist)"
      },
      {
        "command": "letmecook.cloneRepo",
        "title": "LetMeCook: Clone a Repo into New Project",
        "icon": "$(repo-clone)"
      },
      {
        "command": "letmecook.refreshTasks",
        "title": "LetMeCook: Refresh Tasks",
        "icon": "$(refresh)"
      },
      {
        "command": "letmecook.addTask",
        "title": "LetMeCook: Add Task",
        "icon": "$(add)"
      },
      {
        "command": "letmecook.completeTask",
        "title": "Complete Task",
        "icon": "$(check)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "letmecook",
          "title": "LetMeCook",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "letmecook": [
        {
          "id": "letmecookPanel",
          "name": "LetMeCook",
          "type": "tree",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "letmecook.refreshTasks",
          "when": "view == letmecookPanel",
          "group": "navigation@2"
        },
        {
          "command": "letmecook.addTask",
          "when": "view == letmecookPanel",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "letmecook.completeTask",
          "when": "view == letmecookPanel && viewItem == task",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "preinstall": "node -e \"if(!process.env.npm_execpath||!process.env.npm_execpath.includes('pnpm')){console.error('This workspace uses pnpm. Run: pnpm install (from repo root)');process.exit(1)}\"",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "npm run build && npx @vscode/vsce package --no-dependencies --allow-missing-repository --skip-license"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.0.0"
  }
}
