# ─────────────────────────────────────────────────────────────────────────────
# LetMeCook — Environment Variables
# Copy this file to .env and fill in your values:  cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# Random string (min 32 chars) used to sign session cookies.
# Generate one:  openssl rand -hex 32
SESSION_SECRET=

# API key for authenticating VS Code extension requests.
# Generate one:  openssl rand -hex 32
API_KEY=

# ── Paths (Docker defaults are fine — only change for local dev) ──────────────

# Where LetMeCook stores its SQLite database and internal data.
# Docker default: /app/data  |  Local dev example: ~/.letmecook
DATA_DIR=/app/data

# Where your project folders live.
# Docker default: /app/data/projects  |  Local dev example: ~/projects
PROJECTS_DIR=/app/data/projects

# ── Code Server ───────────────────────────────────────────────────────────────

# Hostname/IP of the code-server instance (Docker service name or localhost).
CODE_SERVER_HOST=code-server
CODE_SERVER_PORT=8080

# ── Redis ─────────────────────────────────────────────────────────────────────

# Redis connection URL (Docker service name or localhost).
REDIS_URL=redis://redis:6379

# ── Domain (Optional) ────────────────────────────────────────────────────────

# Your public domain (used for CORS, Cloudflare Tunnel, etc.).
# Leave as localhost if not using a public domain.
DOMAIN=localhost

# Dashboard URL shown in code-server extension.
LETMECOOK_DASHBOARD_URL=http://localhost:3001

# ── Google Drive Backups (Optional) ──────────────────────────────────────────
# Set these to enable automatic project backups to Google Drive.
# Create OAuth2 credentials at: https://console.cloud.google.com
#   → APIs & Services → Credentials → OAuth 2.0 Client ID (Desktop app)

# GDRIVE_OAUTH_CLIENT_ID=
# GDRIVE_OAUTH_CLIENT_SECRET=
# GDRIVE_FOLDER_ID=

# ── AI Providers (Optional — set one or more) ────────────────────────────────
# Enable AI features like task generation, commit messages, repo chat, etc.

# Google Gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# OpenAI / OpenAI-compatible
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=

# Anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
