{
  "name": "letmecook-root",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^9.15.0",
      "onFail": "error"
    }
  },
  "scripts": {
    "preinstall": "node -e \"if(!process.env.npm_execpath||!process.env.npm_execpath.includes('pnpm')){console.error('This repo uses pnpm. Run: pnpm install');process.exit(1)}\"",
    "dev": "pnpm --parallel -r dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "tailwindcss": "^4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "msgpackr-extract",
      "sharp",
      "unrs-resolver"
    ]
  }
}
